# .claude/ is ignored by default, with explicit exceptions for committed scaffolds.
# Use .claude/* (not .claude/) so that re-inclusion of specific subtrees can work
# — git cannot re-include files under a fully-excluded parent directory.
.claude/*
!.claude/agents/
!.claude/agents/**
!.claude/skills/
.claude/skills/*
!.claude/skills/legal-library/
!.claude/skills/legal-library/**
*.env
node_modules/
casecore-runtime/apps/api/casecore/

.vercel/
authority_store/
**/__pycache__/
casecore-runtime/apps/api/config/
casecore-runtime/production/
contract/v1/golden/_legacy_archive/
contract/v1/golden/out/
contract/v1/harness/outputs/
contract/v1/runner/outputs/
docs/.vitepress/cache/
docs/figma/
~$*.docx
*.tmp
contract/v1/acceptance/hash_file.ps1
contract/v1/schemas/commit command.txt
contract/v1/tools/commit command.txt

# Worktrees are never committed as tracked content (NO_DRIFT_WORKING_AGREEMENT R3).
.claude/worktrees/

# Local runtime junk / scratch data — not source of truth.
casecore.db
*.db
tmp_extraction/
casecore-runtime/test_data/
_CACI_CAJI_EVID_FileIndex.csv
