{
  "$id": "casecore.proposal-envelope.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CASECORE Proposal Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proposal_id",
    "proposal_type",
    "matter_id",
    "run_id",
    "schema_version",
    "source_refs",
    "payload",
    "model_metadata",
    "created_at"
  ],
  "properties": {
    "proposal_id": { "type": "string", "pattern": "^PRP-[A-Z0-9_-]+$" },
    "proposal_type": {
      "type": "string",
      "enum": [
        "fact_candidates",
        "event_candidates",
        "tag_proposals",
        "narrative_support",
        "discovery_gaps"
      ]
    },
    "matter_id": { "type": "string", "pattern": "^MTR-[A-Z0-9_-]+$" },
    "run_id": { "type": "string", "pattern": "^RUN-[A-Z0-9_-]+$" },
    "schema_version": { "type": "string", "minLength": 1 },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "payload": { "type": "object" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "rationale": { "type": "string" },
    "model_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "model", "prompt_version"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "prompt_version": { "type": "string", "minLength": 1 }
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
