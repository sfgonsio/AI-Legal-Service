{
  "code": "EVID",
  "section": "1236",
  "title": "Prior Consistent Statement of Witness",
  "text": "Evidence of a statement previously made by a witness is not made inadmissible by the hearsay rule if the statement is consistent with his testimony at the hearing and is offered in compliance with Section 791.",
