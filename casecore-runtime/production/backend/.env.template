# CaseCore backend environment template.
# Copy to ".env" (gitignored) and fill in. NEVER commit real keys.

# --- LLM providers (capability O6: gpt & research, OCR, transcription) ---
# Anthropic Claude = primary reasoning + citations engine.
ANTHROPIC_API_KEY=
# OpenAI = embeddings (RAG index) + Whisper (audio/video transcription) + fallback.
OPENAI_API_KEY=

# --- Model routing (override defaults only if needed) ---
# Claude tiers
CASECORE_REASONING_MODEL=claude-opus-4-8
CASECORE_ROUTINE_MODEL=claude-sonnet-4-6
CASECORE_BULK_MODEL=claude-haiku-4-5-20251001
CASECORE_VISION_MODEL=claude-sonnet-4-6
# OpenAI utility models
CASECORE_EMBEDDING_MODEL=text-embedding-3-large
CASECORE_TRANSCRIPTION_MODEL=whisper-1

# --- Storage (evidence) ---
# Large mixed-media evidence drive. If unset/unavailable, falls back to
# <backend>/storage with a logged warning.
# CASECORE_STORAGE_PATH=F:\CASECORE_STORAGE
