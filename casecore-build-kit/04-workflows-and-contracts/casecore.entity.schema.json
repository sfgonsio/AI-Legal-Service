{
  "$id": "casecore.entity.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CASECORE Entity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "matter_id",
    "artifact_type",
    "schema_version",
    "name",
    "entity_type",
    "created_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^ENT-[A-Z0-9_-]+$" },
    "matter_id": { "type": "string", "pattern": "^MTR-[A-Z0-9_-]+$" },
    "artifact_type": { "const": "ENTITY" },
    "schema_version": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "entity_type": { "type": "string", "minLength": 1 },
    "aliases": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
