# CaseCore Runtime Configuration Template
# Copy this file to .env (backend) and .env.local (frontend) and fill in values

# ════════════════════════════════════════════════════════════════════════════
# RUNTIME GOVERNANCE (Required)
# ════════════════════════════════════════════════════════════════════════════

# Three governed runtimes: sandbox | demo | live
# This determines:
#  - which database is used
#  - what operations are allowed
#  - whether demo shortcuts are accepted
#  - whether reset/seed endpoints work
CASECORE_RUNTIME=demo

# ════════════════════════════════════════════════════════════════════════════
# DATABASE (Backend)
# ════════════════════════════════════════════════════════════════════════════

# For SANDBOX runtime:
#   DATABASE_URL is ignored; uses casecore_sandbox.db automatically
# For DEMO runtime:
#   DATABASE_URL is ignored; uses casecore_demo.db automatically
# For LIVE runtime:
#   DATABASE_URL REQUIRED; point to production PostgreSQL
#   Example: postgresql://user:pass@host:5432/casecore

DATABASE_URL=sqlite+aiosqlite:///./casecore_demo.db

# ════════════════════════════════════════════════════════════════════════════
# ENVIRONMENT (Backend)
# ════════════════════════════════════════════════════════════════════════════

ENVIRONMENT=development     # development | production
PORT=8000

# ════════════════════════════════════════════════════════════════════════════
# API KEYS (Backend)
# ════════════════════════════════════════════════════════════════════════════

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=...

# ════════════════════════════════════════════════════════════════════════════
# PASSWORD GATE (Frontend)
# ════════════════════════════════════════════════════════════════════════════

# Access password for PasswordGate (shown before login)
# For DEMO: typically left empty or set to default
# For LIVE: must be strong and configured securely (via env vars, not in code)
VITE_APP_PASSWORD=JMills!1

# ════════════════════════════════════════════════════════════════════════════
# API ENDPOINT (Frontend)
# ════════════════════════════════════════════════════════════════════════════

# Leave empty for local dev (Vite proxies to localhost:8000)
# For production: point to your backend URL
VITE_API_URL=

# ════════════════════════════════════════════════════════════════════════════
# RUNTIME BEHAVIOR SUMMARY
# ════════════════════════════════════════════════════════════════════════════

# SANDBOX:
#   - Database: ./casecore_sandbox.db (SQLite, isolated)
#   - Demo Login: ALLOWED
#   - Reset Endpoint: ALLOWED
#   - Seed Endpoint: ALLOWED
#   - Use case: Local development, QA testing

# DEMO:
#   - Database: ./casecore_demo.db (SQLite, isolated)
#   - Demo Login: ALLOWED
#   - Reset Endpoint: ALLOWED (locked to DemoBaseline)
#   - Seed Endpoint: ALLOWED (locked to DemoBaseline)
#   - Use case: Client demos, investor presentations

# LIVE:
#   - Database: Production PostgreSQL (from DATABASE_URL)
#   - Demo Login: FORBIDDEN (403)
#   - Reset Endpoint: FORBIDDEN (403)
#   - Seed Endpoint: FORBIDDEN (403)
#   - Use case: Production deployment, real client cases
