{
  "version": 2,
  "name": "casecore",
  "buildCommand": "cd casecore-runtime/apps/api/casecore/frontend && npm install && npm run build",
  "outputDirectory": "casecore-runtime/apps/api/casecore/frontend/dist",
  "installCommand": "npm install",
  "framework": "vite",
  "projectSettings": {
    "nodeVersion": "18.x"
  },
  "env": {
    "PORT": {
      "value": "8000"
    }
  },
  "envs": {
    "development": {
      "CASECORE_RUNTIME": "sandbox",
      "ENVIRONMENT": "development"
    },
    "preview": {
      "CASECORE_RUNTIME": "demo",
      "ENVIRONMENT": "staging",
      "DATABASE_URL": "sqlite+aiosqlite:///./casecore_demo.db"
    },
    "production": {
      "CASECORE_RUNTIME": "live",
      "ENVIRONMENT": "production",
      "DATABASE_URL": "@casecore_db_production",
      "VITE_APP_PASSWORD": "@casecore_password_production"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Runtime",
          "value": "$CASECORE_RUNTIME"
        },
        {
          "key": "X-Environment",
          "value": "$ENVIRONMENT"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "http://localhost:8000/api/$1",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
      "headers": {
        "Access-Control-Allow-Credentials": "true"
      }
    },
    {
      "src": "/static/(.*)",
      "dest": "casecore-runtime/apps/api/casecore/frontend/dist/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "casecore-runtime/apps/api/casecore/frontend/dist/index.html"
    }
  ]
}
