{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://antigravity.local/schemas/pattern_modules/pattern_module.schema.json",
  "title": "Pattern Module (Contract v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "module_id",
    "jurisdiction",
    "version",
    "status",
    "applies_to_archetypes",
    "elements"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["pattern_module.v1"] },
    "module_id": { "type": "string" },
    "jurisdiction": { "type": "string", "description": "e.g., CA" },
    "version": { "type": "string", "description": "Semantic version of module rules, e.g. 1.0.0" },
    "status": { "type": "string", "enum": ["draft", "active", "deprecated", "disabled"] },
    "applies_to_archetypes": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "author": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "reviewed_by": { "type": "array", "items": { "type": "string" }, "default": [] },
        "notes": { "type": "string" }
      }
    },

    "elements": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/element_rule" }
    }
  },

  "definitions": {
    "predicate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "operator"],
      "properties": {
        "path": {
          "type": "string",
          "description": "Dot path into case_signal_profile signals. Example: signals.agreements[*].attributes.exists"
        },
        "operator": { "type": "string", "enum": ["exists", "equals", "contains", "non_empty"] },
        "value": { "type": ["string", "number", "boolean", "null"] }
      }
    },

    "threshold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_required_matches"],
      "properties": {
        "min_required_matches": { "type": "integer", "minimum": 0 },
        "min_supporting_matches": { "type": "integer", "minimum": 0, "default": 0 }
      }
    },

    "element_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "element_id",
        "authority_refs",
        "required_predicates",
        "supporting_predicates",
        "strong_threshold",
        "weak_threshold",
        "evidence_asks",
        "discovery_themes"
      ],
      "properties": {
        "element_id": { "type": "string" },
        "authority_refs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },

        "required_predicates": { "type": "array", "items": { "$ref": "#/definitions/predicate" }, "default": [] },
        "supporting_predicates": { "type": "array", "items": { "$ref": "#/definitions/predicate" }, "default": [] },

        "strong_threshold": { "$ref": "#/definitions/threshold" },
        "weak_threshold": { "$ref": "#/definitions/threshold" },

        "evidence_asks": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },

        "missing_information_prompts": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },

        "discovery_themes": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    }
  }
}