{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "burden_map.schema.json",
  "title": "Burden Map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "jurisdiction",
    "archetype_id",
    "coa_family",
    "jury_instruction_refs",
    "elements"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 3 },
    "jurisdiction": { "type": "string", "minLength": 2 },
    "archetype_id": { "type": "string", "minLength": 3 },
    "coa_family": { "type": "string", "minLength": 2 },
    "jury_instruction_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "elements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "element_id",
          "authority_refs",
          "proof_types"
        ],
        "properties": {
          "element_id": { "type": "string", "minLength": 2 },
          "authority_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 3 }
          },
          "proof_types": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 2 }
          },
          "notes": { "type": "string" }
        }
      }
    },
    "modules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_modules", "conditional_modules"],
      "properties": {
        "default_modules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "conditional_modules": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}