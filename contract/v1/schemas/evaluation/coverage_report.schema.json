{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "coverage_report.schema.json",
  "title": "Coverage Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "created_at",
    "archetype_id",
    "overall_score",
    "elements"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 3 },
    "created_at": { "type": "string", "minLength": 10 },
    "archetype_id": { "type": "string", "minLength": 3 },
    "overall_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "elements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "element_id",
          "coverage_level",
          "score",
          "signal_citations"
        ],
        "properties": {
          "element_id": { "type": "string", "minLength": 2 },
          "coverage_level": {
            "type": "string",
            "enum": ["covered_strong", "covered_weak", "not_covered", "unknown"]
          },
          "score": { "type": "integer", "minimum": 0, "maximum": 2 },
          "signal_citations": {
            "type": "array",
            "minItems": 0,
            "items": { "type": "string", "minLength": 2 }
          },
          "missing_information_prompts": {
            "type": "array",
            "items": { "type": "string" }
          },
          "requested_evidence_types": {
            "type": "array",
            "items": { "type": "string" }
          },
          "discovery_themes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}